# ============================================================
# Revit MCP Server — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Revit / pyRevit Routes connection ---
REVIT_HOST=localhost
REVIT_PORT=48884
REVIT_TIMEOUT=30.0
REVIT_MAX_RETRIES=3

# --- Authentication ---
# Mode: 'none' (dev only), 'api_key', or 'jwt'
REVIT_MCP_AUTH_MODE=api_key

# Static API key (leave blank to auto-generate on first run)
REVIT_MCP_API_KEY=your-secret-key-here

# JWT secret (required if REVIT_MCP_AUTH_MODE=jwt)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
REVIT_MCP_JWT_SECRET=

# JWT token expiry in minutes (default 60)
REVIT_MCP_JWT_EXPIRY_MINUTES=60

# --- Logging ---
# Levels: DEBUG, INFO, WARNING, ERROR
REVIT_MCP_LOG_LEVEL=INFO
# Formats: console, json
REVIT_MCP_LOG_FORMAT=console
REVIT_MCP_LOG_REQUESTS=true

# --- Units ---
# 'metric' (mm input, m² output) or 'imperial' (ft input, ft² output)
REVIT_MCP_UNIT_SYSTEM=metric
